# Copy to .env and fill in values, then:
#   uv run python -m optimizarr
# or:
#   docker compose --env-file .env up
#
# Only secrets and URLs live here. All behavior is in config.toml.

TZ=America/Toronto
LOG_LEVEL=INFO

# Radarr (omit both URL and API_KEY to disable Radarr handling)
RADARR_URL=http://radarr:7878
RADARR_API_KEY=replace-me

# Sonarr (omit both URL and API_KEY to disable Sonarr handling)
SONARR_URL=http://sonarr:8989
SONARR_API_KEY=replace-me
